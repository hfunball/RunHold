<Window x:Class="KeyHold.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyHold"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        Icon="Assets/KeyHold.png"
        Focusable="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="#1D232C" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="#1D232C" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="10,0,32,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Path Width="8"
                                                  Height="5"
                                                  Margin="0,0,12,0"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Data="M 0 0 L 4 5 L 8 0 Z"
                                                  Fill="{DynamicResource TextBrush}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#242C37" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#242C37" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              RecognizesAccessKey="True" />

                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border Background="{DynamicResource PanelBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4" />
                                    <ScrollViewer Margin="2"
                                                  CanContentScroll="True"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#26303D" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#213B4F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentSite"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#242C37" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1D232C" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Panel.ZIndex" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="KeyHold" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Held-key utility for games and simple Windows tasks"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        x:Name="StatusPill"
                        Background="{DynamicResource BorderBrush}"
                        CornerRadius="16"
                        Padding="14,7"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Idle" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="0,16,0,16"
                    Background="{DynamicResource AppBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}">
            <TabItem Header="Status">
                <Grid Margin="14" Background="{DynamicResource AppBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Release All" Click="ReleaseAll_Click" />
                        <Button Content="Hide To Tray" Click="HideToTray_Click" />
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               x:Name="HeldKeysText"
                               Text="No keys held by KeyHold."
                               Margin="0,18,0,0"
                               FontSize="16"
                               TextWrapping="Wrap" />
                </Grid>
            </TabItem>

            <TabItem Header="Bindings">
                <Grid Margin="14" Background="{DynamicResource AppBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.ColumnSpan="2">
                        <TextBlock Text="Activation mode" FontWeight="SemiBold" />
                        <ComboBox x:Name="ActivationModeBox" SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="Separate enable and stop keys" Tag="SeparateKeys" />
                            <ComboBoxItem Content="Single toggle key" Tag="Toggle" />
                            <ComboBoxItem Content="Mouse trigger" Tag="MouseTrigger" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                x:Name="EnableBindingPanel"
                                Margin="0,16,10,0">
                        <TextBlock x:Name="EnableBindingLabel" Text="Enable key" FontWeight="SemiBold" />
                        <TextBox x:Name="EnableBindingText" IsReadOnly="True" Focusable="True" />
                        <Button x:Name="CaptureEnableButton"
                                Content="Set Enable Key"
                                Margin="0,8,8,0"
                                Click="CaptureEnable_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                x:Name="StopBindingPanel"
                                Margin="10,16,0,0">
                        <TextBlock Text="Stop key" FontWeight="SemiBold" />
                        <TextBox x:Name="StopBindingText" IsReadOnly="True" Focusable="True" />
                        <Button x:Name="CaptureStopButton"
                                Content="Set Stop Key"
                                Margin="0,8,8,0"
                                Click="CaptureStop_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                x:Name="EmergencyBindingPanel"
                                Margin="0,16,10,0">
                        <TextBlock Text="Emergency key" FontWeight="SemiBold" />
                        <TextBox x:Name="EmergencyBindingText" IsReadOnly="True" Focusable="True" />
                        <Button x:Name="CaptureEmergencyButton"
                                Content="Set Emergency Key"
                                Margin="0,8,8,0"
                                Click="CaptureEmergency_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="1"
                                x:Name="MouseBindingPanel"
                                Margin="10,16,0,0">
                        <TextBlock Text="Mouse trigger" FontWeight="SemiBold" />
                        <ComboBox x:Name="MouseBindingBox" SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="Mouse Button 4" Tag="XButton1" />
                            <ComboBoxItem Content="Mouse Button 5" Tag="XButton2" />
                            <ComboBoxItem Content="Middle Mouse" Tag="Middle" />
                        </ComboBox>
                    </StackPanel>

                    <CheckBox Grid.Row="3"
                              Grid.ColumnSpan="2"
                              x:Name="SuppressTriggersBox"
                              Content="Suppress trigger key or mouse button so the game does not see it"
                              Checked="SettingChanged"
                              Unchecked="SettingChanged" />
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <StackPanel Margin="14" Background="{DynamicResource AppBackgroundBrush}">
                    <TextBlock Text="Theme" FontWeight="SemiBold" />
                    <ComboBox x:Name="ThemeBox" SelectionChanged="SettingChanged">
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Use Windows setting" Tag="System" />
                    </ComboBox>
                    <CheckBox x:Name="StartupBox"
                              Content="Start KeyHold when Windows starts"
                              Checked="SettingChanged"
                              Unchecked="SettingChanged" />
                    <CheckBox x:Name="LaunchToTrayBox"
                              Content="Launch minimized to tray"
                              Checked="SettingChanged"
                              Unchecked="SettingChanged" />
                    <CheckBox x:Name="NotificationsBox"
                              Content="Show tray notifications"
                              Checked="SettingChanged"
                              Unchecked="SettingChanged" />
                </StackPanel>
            </TabItem>

            <TabItem Header="History">
                <Grid Margin="14" Background="{DynamicResource AppBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent input events. KeyHold records virtual-key state only, not typed text."
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ListBox Grid.Row="1" x:Name="DiagnosticsList" Margin="0,12,0,0" />
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2"
                   Text="Beta warning: intended for single-player use. Some games, elevated apps, and protected processes may ignore synthetic input."
                   Foreground="{DynamicResource MutedTextBrush}"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
